---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Life First Aid Courses | Nationally Recognised Workplace First Aid Training — Blue Mountains & Greater Western Sydney",
  description = "On-Site And Blended Nationally Recognised First Aid Training For High-Risk Industries, Childcare & Education, Hospitality And Community Groups. Audit-Ready Certificates, Flexible Scheduling, 10+ Years' Experience. Based In Blaxland, Serving The Blue Mountains & Greater Western Sydney.",
} = Astro.props;

const canonical = "https://lifefirstaidcourses.com.au";
---

<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#12222c" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_AU" />
    <meta property="og:image" content="/lifefirstaidcourses-logo.png" />

    <!-- Arm reveal animations before first paint -->
    <script is:inline>document.documentElement.classList.add('js-reveal')</script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&family=Public+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

